    "@nestjs/terminus": "^10.2.0",
    "@ecommerce/database": "workspace:*",
    "@ecommerce/shared-types": "workspace:*",
    "@sentry/node": "^7.100.0",
    "bullmq": "^5.1.0",
    "class-transformer": "^0.5.1",
